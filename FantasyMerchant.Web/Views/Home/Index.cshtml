@model FantasyMerchant.Application.Features.FindRoute.FindRouteResponse

<!DOCTYPE html>
<html>
<head>
    <title>Fantasy Merchant - Оптимизатор маршрутов</title>
    <style>
        body { font-family: Arial; margin: 20px; background: #f5f5f5; }
        .container { max-width: 800px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; }
        h1 { color: #2c3e50; }
        .form-group { margin: 15px 0; }
        label { display: inline-block; width: 200px; font-weight: bold; color: #34495e; }
        input, select { padding: 8px 12px; border: 1px solid #bdc3c7; border-radius: 4px; width: 300px; }
        button { padding: 12px 24px; background: #27ae60; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; }
        button:hover { background: #229954; }
        .error { color: #e74c3c; margin: 10px 0; padding: 10px; background: #fadbd8; border-radius: 4px; }
        .result { background: #d5f5e3; padding: 20px; border-radius: 5px; margin: 20px 0; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🏰 Fantasy Merchant</h1>
        <h2>Оптимизатор торговых маршрутов</h2>

        @if (!ViewData.ModelState.IsValid)
        {
                <div class="error">
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    foreach (var error in modelState.Errors)
                    {
                                    <div>@error.ErrorMessage</div>
                    }
                }
                </div>
        }

        <form asp-action="FindRoute" method="post">
            <div class="form-group">
                <label for="StartCityId">Город старта (ID):</label>
                <input type="text" id="StartCityId" name="StartCityId" 
                       placeholder="Например: 00000000-0000-0000-0000-000000000001" 
                       required />
            </div>

            <div class="form-group">
                <label for="EndCityId">Город назначения (ID):</label>
                <input type="text" id="EndCityId" name="EndCityId" 
                       placeholder="Например: 00000000-0000-0000-0000-000000000003" 
                       required />
            </div>

            <div class="form-group">
                <label for="Strategy">Стратегия:</label>
                <select id="Strategy" name="Strategy">
                    <option value="merchant">💰 Торговец (дешевле)</option>
                    <option value="rogue">⚔️ Вор (безопаснее)</option>
                    <option value="balanced">⚖️ Баланс</option>
                </select>
            </div>

            <button type="submit">🗺️ Найти маршрут</button>
        </form>

        @if (Model != null && Model.Success)
        {
                <div class="result">
                    <h3>✅ Маршрут найден!</h3>
                    <p><strong>💰 Всего золота:</strong> @Model.TotalGold</p>
                    <p><strong>⚔️ Всего опасности:</strong> @Model.TotalDanger</p>
                    <p><strong>📍 Шагов:</strong> @Model.TotalSteps</p>

                    <h4>Последовательность городов:</h4>
                    <ol>
                    @foreach (var cityId in Model.Path)
                    {
                                <li>ID: @cityId.Value</li>
                    }
                    </ol>
                </div>
        }
    </div>
</body>
</html>