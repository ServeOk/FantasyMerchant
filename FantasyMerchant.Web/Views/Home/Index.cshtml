@model dynamic

<!DOCTYPE html>
<html>
<head>
    <title>Fantasy Merchant</title>
    <style>
        body { font-family: Arial; margin: 20px; background: #f5f5f5; }
        .container { max-width: 800px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; }
        .form-group { margin: 15px 0; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        select { padding: 10px; border: 1px solid #bdc3c7; border-radius: 4px; width: 100%; }
        button { padding: 12px 24px; background: #27ae60; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; width: 100%; }
        .result { background: #d5f5e3; padding: 20px; border-radius: 5px; margin: 20px 0; }
        .error { background: #fadbd8; padding: 20px; border-radius: 5px; margin: 20px 0; color: #721c24; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🏰 Fantasy Merchant</h1>
        <h2>Оптимизатор торговых маршрутов</h2>

        @* Проверка: если это ViewModel (форма) *@
        @if (Model is FantasyMerchant.Web.Models.FindRouteViewModel viewModel)
        {
                <form asp-action="FindRoute" method="post">
                    <div class="form-group">
                        <label for="StartCityId"> Город старта:</label>
                        <select id="StartCityId" name="StartCityId" required>
                            <option value="">-- Выберите город --</option>
                        @if (viewModel.AvailableCities != null)
                        {
                            @foreach (var city in viewModel.AvailableCities)
                            {
                                            <option value="@city.Id">@city.Name</option>
                            }
                        }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="EndCityId">🏁 Город назначения:</label>
                        <select id="EndCityId" name="EndCityId" required>
                            <option value="">-- Выберите город --</option>
                        @if (viewModel.AvailableCities != null)
                        {
                            @foreach (var city in viewModel.AvailableCities)
                            {
                                            <option value="@city.Id">@city.Name</option>
                            }
                        }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="Strategy">⚙️ Стратегия:</label>
                        <select id="Strategy" name="Strategy">
                            <option value="merchant">💰 Торговец (дешевле)</option>
                            <option value="rogue">⚔️ Вор (безопаснее)</option>
                            <option value="balanced">⚖️ Баланс</option>
                        </select>
                    </div>

                    <button type="submit">🗺️ Найти оптимальный маршрут</button>
                </form>
        }

        @* Проверка: если это Response (результат) *@
        @if (Model is FantasyMerchant.Web.Models.FindRouteResponse response)
        {
            if (response.Success)
            {
                        <div class="result">
                            <h3>✅ Маршрут найден!</h3>
                            <p><strong>💰 Золото:</strong> @response.TotalGold</p>
                            <p><strong>⚔️ Опасность:</strong> @response.TotalDanger</p>
                            <p><strong>📍 Шагов:</strong> @response.TotalSteps</p>

                            <h4>Последовательность городов:</h4>
                            <ol>
                        @foreach (var cityId in response.Path)
                        {
                                        <li>ID: @cityId.Value</li>
                        }
                            </ol>
                        </div>
            }
            else
            {
                        <div class="error">
                            <h3>❌ Ошибка</h3>
                            <p>@response.ErrorMessage</p>
                        </div>
            }

                <a href="/" style="display: inline-block; margin-top: 20px; padding: 10px 20px; background: #3498db; color: white; text-decoration: none; border-radius: 4px;">← Найти другой маршрут</a>
        }
    </div>
</body>
</html>